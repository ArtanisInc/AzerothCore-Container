# Docker build
ACORE_REPO=https://github.com/mod-playerbots/azerothcore-wotlk.git
ACORE_BRANCH=Playerbot
ALE_LUA_VERSION=lua52
BUILD_TYPE=Release
BUILD_JOBS=4
USER_ID=1000
GROUP_ID=1000

# Exposure. Keep 127.0.0.1 for a local-only server.
BIND_ADDRESS=127.0.0.1
AUTH_PORT=3724
WORLD_PORT=8085
SOAP_PORT=7878
REALMLIST_IP=127.0.0.1

# Required secrets. scripts/init-env.sh generates them automatically.
MYSQL_ROOT_PASSWORD=
DB_USER=acore
DB_PASSWORD=
SOAP_USER=soap_admin
SOAP_PASSWORD=

# Runtime
TZ=Europe/Paris
MYSQL_INNODB_BUFFER_POOL_SIZE=4G
DB_BACKUP_DIR=
DB_BACKUP_RETENTION=7

# Better Professions resource density. 1 restores the imported AzerothCore
# baseline; accepted range: 1-10.
BETTER_PROFESSIONS_HERBALISM_MULTIPLIER=6
BETTER_PROFESSIONS_MINING_MULTIPLIER=6
